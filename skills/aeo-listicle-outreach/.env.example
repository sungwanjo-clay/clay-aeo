# Copy to .env in your run directory. NEVER commit real values.

# Supabase — Settings → API → service_role key (secret)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<paste service_role JWT>

# Ahrefs — Account Settings → API Keys (REST or MCP-generated)
AHREFS_TOKEN=<paste>

# Firecrawl — fallback scraper only
FIRECRAWL_API_KEY=<paste>

# Anthropic — used by listicle classifier, pricing extractor, and mention-block generator
ANTHROPIC_API_KEY=<paste>

# Optional: pin Playwright's Chromium (leave unset on local dev)
# PLAYWRIGHT_CHROMIUM_PATH=/opt/pw-browsers/chromium
